# OOP concepts such as classes, objects, methods, and attributes

class Car:
    def __init__    (self, color):
        self.color=color
        
    def start(self):
        print(f"{self.color} car started")
        
#first boject       
my_car=Car("red")
my_car.start()

#second object
my_brother_car=Car("yellow")
my_brother_car.start()

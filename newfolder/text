## 🔹 Question 3: Genetic Algorithm (One-Max Problem)

```python
import random

def fitness(chromosome):
    return sum(chromosome)

def crossover(p1, p2):
    point = random.randint(1, len(p1)-1)
    return p1[:point] + p2[point:], p2[:point] + p1[point:]

def mutate(chromosome, prob=0.1):
    if random.random() < prob:
        idx = random.randint(0, len(chromosome)-1)
        chromosome[idx] = 1 - chromosome[idx]
    return chromosome

# GA loop
population = [[random.randint(0,1) for _ in range(8)] for _ in range(6)]
generation = 0

while True:
    population.sort(key=fitness, reverse=True)
    if fitness(population[0]) == 8 or generation > 100:
        print("Solution:", population[0], "Generation:", generation)
        break
    new_pop = []
    for i in range(0, len(population), 2):
        p1, p2 = population[i], population[i+1]
        c1, c2 = crossover(p1, p2)
        new_pop.append(mutate(c1))
        new_pop.append(mutate(c2))
    population = new_pop
    generation += 1
```

**Goal:** evolve until `[1,1,1,1,1,1,1,1]`.

